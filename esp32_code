float lut(float soc, const float* table) {
    if (soc <= 0.0f) return table[0];
    if (soc >= 1.0f) return table[LUT_N - 1];
    for (int i = 0; i < LUT_N - 1; i++) {
        if (soc <= SOC_PTS[i + 1]) {
            float t = (soc - SOC_PTS[i]) / (SOC_PTS[i + 1] - SOC_PTS[i]);
            return table[i] + t * (table[i + 1] - table[i]);
        }
    }
    return table[LUT_N - 1];
}

float target_c_rate(float speed_kmh, float throttle_pct, bool eco_mode) {
    float thr = throttle_pct / 100.0f;
    if (eco_mode) return 0.67f * thr;
    float c_peak;
    if (speed_kmh < 40.0f) {
        float frac = speed_kmh / 40.0f;
        c_peak = 1.30f + (C_RATE_LAUNCH_PK - 1.30f) * frac;
    } else if (speed_kmh < 70.0f) {
        float frac = (speed_kmh - 40.0f) / 30.0f;
        c_peak = C_RATE_LAUNCH_PK + (C_RATE_ACCEL - C_RATE_LAUNCH_PK) * frac;
    } else {
        c_peak = C_RATE_CRUISE;
    }
    return c_peak * thr;
}

